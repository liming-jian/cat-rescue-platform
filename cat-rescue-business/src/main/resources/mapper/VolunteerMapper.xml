<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.miaoxing.business.mapper.VolunteerMapper">

    <insert id="insert" parameterType="com.miaoxing.business.entity.Volunteer" useGeneratedKeys="true" keyProperty="id">
        insert into volunteers (name, phone, reason)
        values (#{name}, #{phone}, #{reason})
    </insert>

    <select id="findAll" resultType="com.miaoxing.business.entity.Volunteer">
        select id, name, phone, reason, status, apply_date
        from volunteers
        order by id desc
    </select>

    <delete id="deleteById">
        delete from volunteers where id = #{id}
    </delete>
</mapper>
